{
  "name": "my-store",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "backend": "npx json-server data/db.json --port 3000",
    "start": "concurrently \"npm run backend\" \"npm run dev\""
  },
  "dependencies": {
    "axios": "^1.13.2",
    "json-server": "^1.0.0-beta.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vue": "^3.3.8",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.5.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vue-tsc": "^3.2.6"
  }
}